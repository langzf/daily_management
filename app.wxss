page {
  --c-bg: #f2f5ff;
  --c-surface: #ffffff;
  --c-brand: #175dff;
  --c-brand-deep: #12369f;
  --c-accent: #00a6a6;
  --c-text: #1b2559;
  --c-subtext: #5d6b98;
  --c-border: #dfe7ff;
  --c-danger: #d92d20;
  --c-success: #17b26a;
  --shadow-card: 0 16rpx 44rpx rgba(15, 51, 140, 0.09);
  background:
    radial-gradient(circle at 12% 0%, rgba(23, 93, 255, 0.18) 0%, rgba(23, 93, 255, 0) 38%),
    radial-gradient(circle at 100% 16%, rgba(0, 166, 166, 0.15) 0%, rgba(0, 166, 166, 0) 32%),
    var(--c-bg);
  color: var(--c-text);
  font-size: 28rpx;
  font-family: 'Alibaba PuHuiTi 3.0', 'HarmonyOS Sans SC', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.container {
  padding: 22rpx;
}

.hero {
  border-radius: 28rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(136deg, #163fae 0%, #175dff 55%, #20a4b9 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(22, 63, 174, 0.26);
}

.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.hero-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon image {
  width: 34rpx;
  height: 34rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
}

.hero-action {
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  color: #fff;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.12);
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(223, 231, 255, 0.75);
  backdrop-filter: blur(8rpx);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  width: 28rpx;
  height: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 0;
}

.input {
  width: 100%;
  min-height: 76rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 14rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.button {
  margin-top: 16rpx;
  background: linear-gradient(135deg, var(--c-brand-deep) 0%, var(--c-brand) 70%, #20a4b9 100%);
  color: #fff;
  border-radius: 14rpx;
  border: none;
}

.button::after {
  border: none;
}

.button.secondary {
  background: linear-gradient(135deg, #3557b9 0%, #5f77d2 100%);
}

.button.danger {
  background: linear-gradient(135deg, #b42318 0%, var(--c-danger) 100%);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.muted {
  color: var(--c-subtext);
  font-size: 24rpx;
}

.chip-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3151a6;
  font-size: 22rpx;
  border: 1rpx solid #dde6ff;
}

.chip-active {
  background: linear-gradient(135deg, var(--c-brand-deep) 0%, var(--c-brand) 100%);
  color: #ffffff;
  border-color: transparent;
}

.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  font-size: 20rpx;
}

.badge.high {
  background: #ffe5e8;
  color: #c01048;
}

.badge.medium {
  background: #fff1da;
  color: #a65f00;
}

.badge.low {
  background: #e6f7f4;
  color: #0e7a5f;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-done {
  background: var(--c-success);
}

.status-pending {
  background: #99a8cf;
}

.list-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2ff;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.row-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.row-actions button {
  margin: 0;
}

.small-button {
  border-radius: 10rpx;
  background: #edf3ff;
  color: #2446a8;
  border: none;
  font-size: 22rpx;
  line-height: 1.4;
  padding: 0 12rpx;
}

.small-button.warn {
  background: #ffe9ea;
  color: #b42318;
}

.small-button::after {
  border: none;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.kpi-item {
  border-radius: 14rpx;
  background: #f5f8ff;
  border: 1rpx solid #e2eaff;
  padding: 12rpx;
}

.kpi-label {
  font-size: 20rpx;
  color: #6f7fac;
}

.kpi-value {
  font-size: 30rpx;
  color: #163fae;
  font-weight: 600;
  margin-top: 4rpx;
}
