page {
  background: #f5f7fb;
  color: #1f2329;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  min-height: 72rpx;
  border: 1rpx solid #d9e1ec;
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: #fff;
}

.button {
  margin-top: 16rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}
