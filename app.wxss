page {
  --c-bg: #eef2ff;
  --c-surface: #ffffff;
  --c-surface-soft: #f3f7ff;
  --c-brand: #2563eb;
  --c-brand-deep: #1e40af;
  --c-brand-soft: #e0e7ff;
  --c-text: #0f172a;
  --c-subtext: #64748b;
  --c-border: #dbe3f3;
  --c-danger: #dc2626;
  --c-success: #16a34a;
  --shadow-card: 0 10rpx 28rpx rgba(15, 23, 42, 0.08);
  background: linear-gradient(180deg, #f8fbff 0%, var(--c-bg) 100%);
  color: var(--c-text);
  font-size: 28rpx;
  font-family: 'Alibaba PuHuiTi 3.0', 'HarmonyOS Sans SC', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.container {
  padding: 24rpx;
}

.hero {
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  color: var(--c-text);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: var(--c-brand-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon image {
  width: 32rpx;
  height: 32rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: var(--c-subtext);
  font-size: 24rpx;
}

.hero-action {
  border: 1rpx solid #c7d7ff;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  color: var(--c-brand-deep);
  font-size: 22rpx;
  background: var(--c-brand-soft);
}

.card {
  background: var(--c-surface);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--c-border);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  width: 28rpx;
  height: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 0;
}

.input {
  width: 100%;
  min-height: 76rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.button {
  margin-top: 16rpx;
  width: 100%;
  min-height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  background: #2f63d6;
  color: #f8fbff;
  border-radius: 14rpx;
  border: 1rpx solid #4a79e0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 3rpx 10rpx rgba(37, 99, 235, 0.16);
}

.button::after {
  border: none;
}

.button.button-hover {
  opacity: 0.92;
  transform: translateY(1rpx);
}

.button.secondary {
  background: linear-gradient(135deg, #334155 0%, #475569 100%);
  border-color: #64748b;
  box-shadow: 0 6rpx 14rpx rgba(51, 65, 85, 0.16);
}

.button.danger {
  background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
  border-color: #f87171;
  box-shadow: 0 6rpx 14rpx rgba(220, 38, 38, 0.16);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.muted {
  color: var(--c-subtext);
  font-size: 24rpx;
}

.chip-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f9fbff;
  color: #334155;
  font-size: 22rpx;
  border: 1rpx solid var(--c-border);
}

.chip-active {
  background: var(--c-brand);
  color: #ffffff;
  border-color: var(--c-brand);
}

.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  font-size: 20rpx;
}

.badge.high {
  background: #fee2e2;
  color: #b91c1c;
}

.badge.medium {
  background: #fef3c7;
  color: #92400e;
}

.badge.low {
  background: #dcfce7;
  color: #166534;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-done {
  background: var(--c-success);
}

.status-pending {
  background: #94a3b8;
}

.list-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2ff;
}

.list-row:last-child {
  border-bottom: none;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.row-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.row-actions button {
  margin: 0;
}

.small-button {
  border-radius: 10rpx;
  background: #f8fafc;
  color: #334155;
  border: 1rpx solid #dbe3f3;
  font-size: 22rpx;
  line-height: 1.4;
  padding: 0 12rpx;
}

.small-button.warn {
  background: #fff5f5;
  color: #b91c1c;
  border-color: #fecaca;
}

.small-button::after {
  border: none;
}

.switch-compact {
  transform: scale(0.86);
  transform-origin: 100% 50%;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.kpi-item {
  border-radius: 12rpx;
  background: var(--c-surface-soft);
  border: 1rpx solid var(--c-border);
  padding: 12rpx;
}

.kpi-label {
  font-size: 20rpx;
  color: var(--c-subtext);
}

.kpi-value {
  font-size: 30rpx;
  color: var(--c-brand-deep);
  font-weight: 600;
  margin-top: 4rpx;
}
