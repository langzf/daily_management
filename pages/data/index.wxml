<view class="container">
  <view class="card">
    <view class="section-title">数据概览</view>
    <block wx:for="{{stats}}" wx:key="key">
      <view class="row" style="padding: 10rpx 0; border-bottom: 1rpx solid #f0f2f5;">
        <text>{{item.label}}</text>
        <text class="muted">{{item.count}} 条</text>
      </view>
    </block>
  </view>

  <view class="card">
    <view class="section-title">导出备份</view>
    <view class="muted" wx:if="{{lastExportAt}}" style="margin-bottom: 10rpx;">最近导出：{{lastExportAt}}</view>
    <view class="row" style="justify-content: flex-start; gap: 12rpx; margin-bottom: 12rpx;">
      <button size="mini" bindtap="generateExport">生成导出内容</button>
      <button size="mini" bindtap="copyExport">复制到剪贴板</button>
    </view>
    <textarea class="textarea" value="{{exportText}}" placeholder="点击“生成导出内容”" maxlength="-1" disabled="{{true}}"></textarea>
  </view>

  <view class="card">
    <view class="section-title">导入恢复</view>
    <view class="muted" style="margin-bottom: 10rpx;">请粘贴完整导出 JSON，导入会覆盖现有四个模块数据。</view>
    <textarea class="textarea" value="{{importText}}" placeholder="在此粘贴导出 JSON" maxlength="-1" bindinput="onImportInput"></textarea>
    <button class="button" bindtap="importData">执行导入</button>
  </view>

  <view class="card">
    <view class="section-title">危险操作</view>
    <view class="muted" style="margin-bottom: 12rpx;">清空前建议先导出备份。</view>
    <button class="button danger" bindtap="clearAll">清空全部数据</button>
  </view>
</view>
