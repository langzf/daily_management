@import "../../app.wxss";

.textarea {
  width: 100%;
  min-height: 220rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 14rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 24rpx;
}

.field-label {
  font-size: 24rpx;
  color: var(--c-subtext);
  margin-bottom: 8rpx;
}

.switch-row {
  margin-top: 14rpx;
}

.sync-actions {
  justify-content: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.sync-status {
  margin-top: 12rpx;
}

.auth-line {
  word-break: break-all;
  margin-bottom: 4rpx;
}
