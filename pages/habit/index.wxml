<view class="container">
  <view class="row" style="justify-content:flex-end; margin-bottom:10rpx;">
    <navigator class="chip" url="/pages/data/index">数据管理</navigator>
  </view>
  <view class="card">
    <view class="section-title">新增习惯</view>
    <input class="input" placeholder="例如：晨跑20分钟" value="{{newName}}" bindinput="onInput" />
    <button class="button" bindtap="addHabit">添加习惯</button>
  </view>

  <view class="card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">今日打卡</view>
      <text class="muted">已完成 {{summary.doneToday}} / {{summary.total}}</text>
    </view>
    <block wx:if="{{list.length === 0}}">
      <view class="muted">暂无习惯，先添加一个打卡目标。</view>
    </block>
    <block wx:for="{{list}}" wx:key="id">
      <view class="row" style="padding: 12rpx 0; border-bottom: 1rpx solid #f0f2f5;">
        <view style="flex:1;">
          <view class="row" style="justify-content:flex-start; align-items:center;">
            <view class="status-dot {{item.checkedToday ? 'status-done' : 'status-pending'}}"></view>
            <view>{{item.name}}</view>
          </view>
          <view class="muted">连续 {{item.streak}} 天 · 最近打卡 {{item.lastCheckDate || '暂无'}}</view>
        </view>
        <button size="mini" bindtap="checkIn" data-id="{{item.id}}">{{item.checkedToday ? '已打卡' : '打卡'}}</button>
        <button size="mini" type="warn" bindtap="remove" data-id="{{item.id}}">删除</button>
      </view>
    </block>
  </view>
</view>
